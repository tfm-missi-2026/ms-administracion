# --- ms-administracion standalone ---
# Puerto host donde se expone la API (el contenedor escucha en 8081)
APP_PORT=8081
# Puerto host de PostgreSQL
DB_PORT=5432
# PostgreSQL: la BD y el usuario se crean automaticamente con estos valores
DB_NAME=spsrt_administracion
DB_USER=spsrt_administracion_user
DB_PASSWORD=spsrt_administracion_pwd
# JWT: este servicio EMITE los tokens; el secreto debe ser el mismo del resto del stack
JWT_SECRET=cambiar-esta-clave-en-produccion-minimo-32-bytes-aleatorios
